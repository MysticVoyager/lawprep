# LawPrep — example environment file
# ----------------------------------------------------------------------
# Copy this file to `.env` (in the same folder as this example) and fill
# in any keys you want to enable. The portal works fully offline without
# any of these — they only power optional AI / audio features.
#
#   cp .env.example .env
#
# Never commit your real .env to git.
# ----------------------------------------------------------------------

# Flask session secret. Generate a random string for production use, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Google Gemini API key — powers AI-generated lesson takeaways, quizzes
# and the in-lesson tutor explanations.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ElevenLabs API key — powers high-quality text-to-speech narration for
# lessons. Without this, lessons can still be read with the browser's
# built-in speech synthesis.
# Get a free key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Anthropic API key — powers the "Explain this paragraph" Claude tutor
# feature inside lessons. Optional.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
